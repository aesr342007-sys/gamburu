{
  "version": 2,
  "builds": [
    { "src": "api/notify.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "tonconnect-manifest.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/notify", "dest": "/api/notify.js" },
    { "src": "/tonconnect-manifest.json", "dest": "/tonconnect-manifest.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
